  "krakkavaktin": {
    "title": "Krakkavaktin",
    "status": "In development",
    "subtitle": "Can Siggi come play?",
    "description": "Parents use Messenger, for example, to ask if the kids can hang out. But Messenger is full of other unread messages, emotions and awkwardness that have no place in the context of whether your child is going out to play. Krakkavaktin is just messaging, where the child is always at the centre. Conversations disappear once play is over, making this a true peace of mind tool.\n\nShould I message the mum or the dad, or both? Isn't the aunt with him on Tuesdays? You no longer need to think about this. You just message 'Siggi' and whoever is registered behind Siggi gets the message.",
    "messengerQuote": "Messenger works, but it's full of everything else you don't want to think about when you're just trying to arrange a playdate. Krakkavaktin is a small, calm place for that one conversation.",
    "whyTitle": "Why this works",
    "features": {
      "chat": "Just messaging, nothing else",
      "chat_desc": "One question, one answer. No dashboards.",
      "child": "Child in focus",
      "child_desc": "The conversation is about Siggi, never the parents.",
      "disappear": "Conversations disappear",
      "disappear_desc": "When play is over, so is this.",
      "calm": "No anxiety",
      "calm_desc": "No read receipts, no typing indicators."
    },
    "waitlistTitle": "Get notified when Krakkavaktin launches",
    "waitlistDesc": "We're putting the finishing touches on it. You'll get one email when it's ready, nothing else.",
    "waitlistPlaceholder": "email@example.com",
    "waitlistButton": "Notify me",
    "waitlistSuccess": "Great! We'll let you know.",
    "cta": "Go to Krakkavaktin.is",
    "back": "← Back"
  },
