# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin login (email-code flow)
ADMIN_EMAILS=you@example.com
AUTH_CODE_SECRET=         # generate: openssl rand -hex 32
UNSUBSCRIBE_SECRET=       # generate: openssl rand -hex 32

# Voting abuse prevention
VOTE_SECRET=              # generate: openssl rand -hex 32

# Email (Resend) — optional in dev, codes printed to console if missing
RESEND_API_KEY=
EMAIL_FROM=Teskeið <teskeid@mail.gottvibe.is>
REPLY_TO=

# App
NEXT_PUBLIC_SITE_URL=https://teskeid.is

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Cron
CRON_SECRET=

# Feature flags
LOANS_ENABLED=true
UMONNUN_ENABLED=
# UMONNUN_FLAG=true  # uncomment to enable per-user access control via feature_access table
                     # if unset or false: all logged-in users see Umönnun (when UMONNUN_ENABLED=true)
TENGSL_ENABLED=
# TENGSL_FLAG=true   # uncomment to enable per-user access control via feature_access table
                     # if unset or false: all logged-in users see Tengsl (when TENGSL_ENABLED=true)
FACEBOOK_OAUTH_ENABLED=
# FACEBOOK_OAUTH_FLAG=true  # uncomment to enable per-user access control via feature_access table
                             # if unset or false: all logged-in users see Facebook section (when FACEBOOK_OAUTH_ENABLED=true)
# WEATHER_ENABLED=All          # 'All' → everyone (public + auth) gets base MET/Yr weather
                               # 'Authenticated' → only signed-in users get base weather
                               # any other value / unset → weather is fully closed
                               # Legacy: WEATHER_ENABLED=true + WEATHER_PUBLIC_ENABLED=true → same as 'All'
                               # Legacy: WEATHER_ENABLED=true (no public flag) → same as 'Authenticated'
WEATHER_ENABLED=
# WEATHER_PUBLIC_ENABLED is superseded by WEATHER_ENABLED=All.
# Remove from Vercel after verifying new mode is deployed and working.
WEATHER_PUBLIC_ENABLED=
# WEATHER_AUTH_ACCESS_REQUIRED=true   # require feature_access row (vedrid) for /auth-mvp/vedrid
                                      # only applies in Authenticated mode (in All mode, vedrid is not required)
                                      # if unset or false: all authenticated users have access (graduation path)
# WEATHER_TRIP_FLAG=true     # enable per-user access control for the hidden Ferðalag affordance
                             # if unset or false: Ferðalag affordance is hidden for all users
# WEATHER_ELTA_VEDRID_FLAG=true  # enable per-user access for the hidden Elta veðrið validation view
                                 # if unset or false: Elta veðrið is hidden/blocked for all users
# WEATHER_PROVIDER_VEDURSTOFAN_ACCESS_REQUIRED=true  # require feature_access row (weather-provider-vedurstofan) for Veðurstofan layer
                                                      # default (unset/false/anything else): open to all weather users — the graduation path (delete this var to graduate)
                                                      # set to true to enable per-user gate via feature_access table
                                                      # legacy WEATHER_PROVIDER_VEDURSTOFAN_ENABLED is no longer read by code — remove from Vercel after deploy verification
# WEATHER_PROVIDER_VEGAGERDIN_ACCESS_REQUIRED=true   # require feature_access row (weather-provider-vegagerdin) for Vegagerðin current-measurement layer
                                                      # default (unset or false): open to all weather users (graduation path)
                                                      # set to true to gate access per-user via feature_access table
                                                      # sql/80 must be run before granting any rows
WEATHER_AI_ENABLED=
WEATHER_AGENT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
METNO_USER_AGENT=Teskeidin/1.0 (+https://teskeid.is; teskeid@gottvibe.is)

# Google Maps Platform (Phase 2A2 — route + map confirmation)
# Server key: restricted to Geocoding API + Routes API only. Never sent to browser.
GOOGLE_MAPS_SERVER_KEY=
# Browser key: restricted to Maps JS API + Places API (New) + Maps Static API.
# HTTP referrer restrictions: https://teskeid.is/*, https://*.teskeid.is/*, http://localhost:*/*
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# Provider toggle. Set to "google" to enable map confirmation and route weather.
WEATHER_MAP_PROVIDER=
# Reverse geocode BFF (Nominatim proxy). Must be explicitly set to "true" to enable (opt-in).
# Requires AUTH_MVP_ENABLED=true + vedrid feature access. Default disabled for production safety.
ENABLE_REVERSE_GEOCODE=
