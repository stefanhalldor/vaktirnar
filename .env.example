# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin login (email-code flow)
ADMIN_EMAILS=you@example.com
AUTH_CODE_SECRET=         # generate: openssl rand -hex 32
UNSUBSCRIBE_SECRET=       # generate: openssl rand -hex 32

# Voting abuse prevention
VOTE_SECRET=              # generate: openssl rand -hex 32

# Email (Resend) — optional in dev, codes printed to console if missing
RESEND_API_KEY=
EMAIL_FROM=Teskeið <teskeid@mail.gottvibe.is>
REPLY_TO=

# App
NEXT_PUBLIC_SITE_URL=https://teskeid.is

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Cron
CRON_SECRET=

# Feature flags
LOANS_ENABLED=true
UMONNUN_ENABLED=
# UMONNUN_FLAG=true  # uncomment to enable per-user access control via feature_access table
                     # if unset or false: all logged-in users see Umönnun (when UMONNUN_ENABLED=true)
TENGSL_ENABLED=
# TENGSL_FLAG=true   # uncomment to enable per-user access control via feature_access table
                     # if unset or false: all logged-in users see Tengsl (when TENGSL_ENABLED=true)
FACEBOOK_OAUTH_ENABLED=
# FACEBOOK_OAUTH_FLAG=true  # uncomment to enable per-user access control via feature_access table
                             # if unset or false: all logged-in users see Facebook section (when FACEBOOK_OAUTH_ENABLED=true)
